# Root-level ignores for the monorepo. Each app (frontend/, backend/) also has
# its own .gitignore; the rules below are global safety nets that catch stray
# artifacts anywhere in the tree.

# ---- OS ----
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Editors / IDEs ----
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- Env files (committed examples like .env.example are kept) ----
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ---- Logs ----
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Node / Next.js (frontend) ----
node_modules/
.pnp
.pnp.*
.next/
out/
build/
coverage/
*.tsbuildinfo
.vercel

# ---- Java / Maven (backend) ----
target/
*.class
*.jar
!**/.mvn/wrapper/maven-wrapper.jar
HELP.md

# ---- Misc ----
*.pem
.cache/
tmp/
