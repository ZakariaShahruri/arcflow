# Base URL of the arcflow Spring Boot backend.
# Used by src/lib/api.ts. Copy this file to .env.local for local dev.
NEXT_PUBLIC_API_URL=http://localhost:8090

# Neon Postgres connection string (used by Drizzle for the waitlist).
# Get it from the Neon console or the Vercel Marketplace integration.
# Use the pooled connection string for serverless/Server Actions.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
